<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="56dp"
        android:paddingBottom="32dp">

        <!-- Network banner (hidden when connected) -->
        <TextView
            android:id="@+id/networkBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📵  无网络连接，部分播报内容将使用缓存"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="@color/warning"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="晨光"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:letterSpacing="0.02"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Morning Grace"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- ── Alarm Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="闹钟"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/alarmSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Big time display -->
                <TextView
                    android:id="@+id/timeDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="06:00"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:paddingVertical="4dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击修改时间"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <!-- Permission warning -->
                <TextView
                    android:id="@+id/permissionWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="⚠️  需要精确闹钟权限，请在设置中开启"
                    android:textSize="13sp"
                    android:textColor="@color/warning"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Modules Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播报内容"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <CheckBox
                    android:id="@+id/moduleWeather"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌤  天气播报"
                    android:textSize="15sp"
                    android:textColor="@color/text_label"
                    android:checked="true"
                    android:layout_marginBottom="4dp" />

                <CheckBox
                    android:id="@+id/moduleBible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📖  圣经读经"
                    android:textSize="15sp"
                    android:textColor="@color/text_label"
                    android:checked="true"
                    android:layout_marginBottom="2dp" />

                <!-- Reading plan — indented, shown only when Bible is checked -->
                <RadioGroup
                    android:id="@+id/planRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="36dp"
                    android:layout_marginBottom="8dp">

                    <RadioButton
                        android:id="@+id/planMcCheyne"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="麦大卫一年读经"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="2dp" />

                    <RadioButton
                        android:id="@+id/planSequential"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="顺序读经（创世记 → 启示录）"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="2dp" />

                    <RadioButton
                        android:id="@+id/planChapterADay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="每天一章"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />

                </RadioGroup>

                <CheckBox
                    android:id="@+id/moduleFinance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📈  财经行情"
                    android:textSize="15sp"
                    android:textColor="@color/text_label"
                    android:checked="true"
                    android:layout_marginBottom="4dp" />

                <CheckBox
                    android:id="@+id/moduleNews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📰  新闻头条"
                    android:textSize="15sp"
                    android:textColor="@color/text_label"
                    android:checked="true" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Location Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="位置"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/locationStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:text="位置未设置"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/locationButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="更新当前位置"
                    app:icon="@android:drawable/ic_menu_mylocation"
                    app:iconGravity="textStart" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── AI Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖  AI 语音对话"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="播报结束后进入 AI 对话，需要 Gemini API Key"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Gemini API Key"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/geminiApiKeyInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textSize="13sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveApiKeyButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="保存"
                    android:textSize="14sp"
                    app:backgroundTint="@color/accent" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Dev / Test Card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/bg_card_dev">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="开发测试"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_dev"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/testBroadcastButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="立即测试播报"
                    app:backgroundTint="@color/accent_dev" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
