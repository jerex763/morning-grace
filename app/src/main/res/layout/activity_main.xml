<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/networkBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/warning"
            android:gravity="center"
            android:padding="8dp"
            android:text="无网络连接，摘要将使用上次内容"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="286dp"
            android:background="@drawable/bg_morning_hero"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp">

            <View
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="34dp"
                android:layout_marginTop="56dp"
                android:background="@drawable/bg_sun" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginBottom="22dp"
                android:text="⌁  ︿  ⌁"
                android:textColor="#B99162"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="serif"
                        android:text="晨光"
                        android:textColor="@color/accent_dark"
                        android:textSize="42sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/settingsButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_round_outline"
                        android:clickable="true"
                        android:contentDescription="打开播报设置"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="⚙"
                        android:textColor="@color/text_label"
                        android:textSize="24sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-4dp"
                    android:fontFamily="serif"
                    android:text="愿你的早晨有光，心中有望。"
                    android:textColor="@color/text_label"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/dateDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="serif"
                    android:text="2026年7月20日  星期一"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="208dp"
                    android:layout_height="76dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#EFFFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:strokeColor="#D9C3A7"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_rust"
                            android:gravity="center"
                            android:text="◷"
                            android:textColor="#FFFFFF"
                            android:textSize="25sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="下次播报"
                                android:textColor="@color/text_label"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/timeDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="serif"
                                android:text="06:00"
                                android:textColor="@color/accent_dark"
                                android:textSize="25sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="●"
                            android:textColor="@color/olive"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/permissionWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="22dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="需要精确闹钟权限"
            android:textColor="@color/warning"
            android:textSize="12sp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="18dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:text="—  今日读经  —"
                    android:textColor="@color/text_label"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/biblePlanSelector"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="麦大卫一年读经  ⌄"
                    android:textColor="@color/accent_dark"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/bibleProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:paddingVertical="4dp"
                    android:text="第 204 / 365 天"
                    android:textColor="@color/accent_dark"
                    android:textSize="34sp" />

                <View
                    android:layout_width="160dp"
                    android:layout_height="1dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/gold_soft" />

                <TextView
                    android:id="@+id/bibleReadingPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:lineSpacingExtra="7dp"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="8dp"
                    android:text="1  约书亚记第十七章&#10;2  箴言第十二章&#10;3  约翰福音第十九章&#10;4  腓立比书第四章"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" />

                <LinearLayout
                    android:id="@+id/bibleProgressRow"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_day_navigation"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/biblePreviousDay"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:contentDescription="上一个计划日"
                        android:text="‹  前一天"
                        android:textColor="@color/text_label"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/bibleDayPickerButton"
                        android:layout_width="40dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:contentDescription="选择计划日"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="▣"
                        android:textColor="@color/text_label"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/bibleNextDay"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:contentDescription="下一个计划日"
                        android:text="后一天  ›"
                        android:textColor="@color/text_label"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testBroadcastButton"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:text="开始晨间播报"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/accent_dark"
            app:cornerRadius="18dp"
            app:icon="@android:drawable/ic_btn_speak_now"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="128dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_olive"
                        android:gravity="center"
                        android:text="☁︎"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="serif"
                        android:text="天气"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/weatherSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="2"
                        android:text="正在更新…"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_rust"
                        android:gravity="center"
                        android:text="↗"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="serif"
                        android:text="财经"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/financeSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="2"
                        android:text="正在更新…"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_olive"
                        android:gravity="center"
                        android:text="▤"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="serif"
                        android:text="新闻"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/newsSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="2"
                        android:text="正在更新…"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/bg_reading"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingTop="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="❝"
                    android:textColor="@color/gold"
                    android:textSize="30sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:includeFontPadding="true"
                    android:fontFamily="serif"
                    android:lineSpacingExtra="5dp"
                    android:paddingBottom="6dp"
                    android:text="这正是我所喜悦的：要怜悯，不是祭祀；认识神，胜于燔祭。&#10;—— 何西阿书 6:6"
                    android:textColor="@color/text_label"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_settings_panel"
            android:orientation="vertical"
            android:padding="18dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="播报设置"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/alarmSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="启用每日晨间闹钟"
                android:textColor="@color/text_label"
                app:useMaterialThemeColors="true" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/moduleBible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="圣经读经"
                android:textColor="@color/text_label"
                app:useMaterialThemeColors="true" />

            <RadioGroup
                android:id="@+id/planRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/planMcCheyne"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="麦大卫一年读经"
                    android:textColor="@color/text_label" />

                <RadioButton
                    android:id="@+id/planSequential"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="顺序读经（创世记 → 启示录）"
                    android:textColor="@color/text_label" />

                <RadioButton
                    android:id="@+id/planChapterADay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="每天三章"
                    android:textColor="@color/text_label" />
            </RadioGroup>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/bibleEnglish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="同时播报英文经文"
                android:textColor="@color/text_secondary"
                app:useMaterialThemeColors="true" />

            <TextView
                android:id="@+id/chineseSpeechRateLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="中文语速：自然（0.88×）"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/chineseSpeechRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="50"
                android:progress="18" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/moduleWeather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="天气播报"
                android:textColor="@color/text_label"
                app:useMaterialThemeColors="true" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/moduleFinance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="财经行情"
                android:textColor="@color/text_label"
                app:useMaterialThemeColors="true" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/moduleNews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="新闻头条"
                android:textColor="@color/text_label"
                app:useMaterialThemeColors="true" />

            <TextView
                android:id="@+id/locationStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="位置未设置"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/locationButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="更新天气位置"
                app:icon="@android:drawable/ic_menu_mylocation" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="serif"
                android:text="AI 语音对话 · 可选"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="8dp"
                android:text="不填写不影响晨间播报。"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Gemini API Key">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/geminiApiKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveApiKeyButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="保存 Key"
                app:backgroundTint="@color/accent" />
        </LinearLayout>

        <!-- Keep the final card and its last line above gesture/navigation insets. -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="56dp" />
    </LinearLayout>
</ScrollView>
